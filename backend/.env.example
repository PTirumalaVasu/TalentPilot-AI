DATABASE_URL=postgresql+asyncpg://talentpilot:talentpilot@localhost:5432/talentpilot
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION_HOURS=24
# Comma-separated list of allowed CORS origins. Local dev + the built SPA's
# served origin (fill in once the frontend build/serve target is decided).
ALLOWED_ORIGINS=http://localhost:5173
SESSION_COOKIE_NAME=access_token
# Secure flag on the session cookie. Defaults True to match production intent,
# but the local dev loop (uvicorn + Vite) runs over plain HTTP with no TLS --
# a real browser will silently refuse to send a Secure cookie back over HTTP.
# Set to False in your local .env for real browser testing.
COOKIE_SECURE=True
